# Transport Mode
# redis = standalone up to 100K devices
# kafka = distributed 100K to 10M devices
TRANSPORT_MODE=redis

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=netfleet

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Kafka — only needed when TRANSPORT_MODE=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=netfleet-workers

# Discovery
DISCOVERY_MODE=cron
PRIMARY_DB_URI=jdbc:hive2://localhost:10000
SECONDARY_FILES_PATH=/data/discovery/files
DELTA_THRESHOLD_PERCENTAGE=10

# Preprocessor
THREAD_POOL_SIZE=150
MAX_INSTANCES=6
DEVICE_TIMEOUT=30
AUTH_RETRY_COUNT=2
ERROR_THRESHOLD=100

# Postprocessor
TEXTFSM_TEMPLATES_PATH=/app/templates/textfsm
POSTPROCESSOR_ERROR_THRESHOLD=100
POSTPROCESSOR_BATCH_SIZE=50

# Scheduler
JOB_CHECK_INTERVAL=30
QUEUE_POLL_INTERVAL=5
JOB_TIMEOUT_MINUTES=120

# Cache
CACHE_TIMEOUT_MINUTES=30

# Simulator
SIMULATOR_HOST=0.0.0.0
SIMULATOR_PORT=8888
SIMULATOR_DEVICE_COUNT=100

# Logging
LOG_LEVEL=INFO

# Phase 2 — Natural Language Query (Claude API)
ANTHROPIC_API_KEY=

# Phase 3 — Qdrant vector store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=netfleet_device_output

# Phase 3 — RAG Indexer
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CHUNK_TOKENS=512
RAG_BATCH_SIZE=20

# Phase 2 — NL Query limits
NL_QUERY_MAX_RESULTS=50
NL_QUERY_TIMEOUT_SECONDS=30
